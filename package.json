{
  "name": "@lowdefy/modules-mongodb",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "description": "Lowdefy MongoDB Modules",
  "packageManager": "pnpm@10.6.2",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter '!@lowdefy/modules-demo' run build",
    "changeset": "changeset",
    "docs:check": "node scripts/gen-var-docs.mjs --check && node scripts/gen-llms-txt.mjs --check",
    "docs:gen": "node scripts/gen-var-docs.mjs && node scripts/gen-llms-txt.mjs",
    "release:version": "pnpm changeset version && node scripts/sync-module-versions.mjs && pnpm install --no-frozen-lockfile",
    "release:publish": "pnpm changeset publish",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.29.4",
    "@swc/jest": "^0.2.37",
    "jest": "^29.7.0",
    "js-yaml": "4.1.1",
    "mongodb": "^6.10.0",
    "mongodb-memory-server": "^10.1.2",
    "prettier": "^3.8.4"
  },
  "pnpm": {
    "packageExtensions": {
      "@lowdefy/client": {
        "dependencies": {
          "antd": "6.3.1"
        }
      }
    },
    "onlyBuiltDependencies": [
      "mongodb-memory-server"
    ]
  }
}
