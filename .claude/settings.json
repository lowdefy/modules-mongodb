{
  "extraKnownMarketplaces": {
    "resonancy": {
      "source": {
        "source": "github",
        "repo": "TECHMRM/claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "r@resonancy": true
  },
  "sandbox": {
    "enabled": true,
    "excludedCommands": [
      "gh",
      "pnpm e2e*",
      "pnpm --filter @lowdefy/modules-demo e2e*"
    ],
    "network": {
      "allowedDomains": ["github.com", "api.github.com", "registry.npmjs.org"]
    },
    "filesystem": {
      "allowWrite": ["~/Library/pnpm", "~/Library/Caches/pnpm"]
    }
  },
  "enabledMcpjsonServers": ["lowdefy-docs"]
}
