{
  "name": "@lowdefy/modules-workflows-test",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "ldf:b": "lowdefy build",
    "ldf": "lowdefy dev --no-open --port 3001",
    "e2e": "playwright test --config=e2e/playwright.config.js",
    "e2e:headed": "SLOW_MO=500 playwright test --headed --workers=1 --config=e2e/playwright.config.js",
    "e2e:ui": "playwright test --ui --config=e2e/playwright.config.js",
    "e2e:server": "lowdefy build --server e2e && lowdefy start --port 3001 --log-level warn"
  },
  "dependencies": {
    "lowdefy": "0.0.0-experimental-20260722143027"
  },
  "devDependencies": {
    "@lowdefy/e2e-utils": "0.0.0-experimental-20260722143027",
    "@playwright/test": "^1.50.0",
    "@lowdefy/community-plugin-e2e-mdb": "latest"
  }
}
