{
  "name": "@lowdefy/modules-mongodb-plugins",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./dist/*",
    "./actions": "./dist/actions.js",
    "./blocks": "./dist/blocks.js",
    "./types": "./dist/types.js"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "swc src --out-dir dist --config-file ../../.swcrc --delete-dir-on-start --copy-files --strip-leading-paths",
    "clean": "rm -rf dist",
    "prepare": "pnpm build"
  },
  "devDependencies": {
    "@swc/cli": "0.6.0",
    "@swc/core": "1.11.24"
  }
}
