# Writable edit page for a form action.
#
# Build-time vars (from makeActionPages.js): action_config, page_config,
# page_ids, workflow_type, connection_id, workflow_title, reference_field,
# entity_view_slot. See view.yaml.njk for the full schema. The entity instance
# name arrives on get_workflow_action.entity_link.name (Part 26, from the
# workflow's entity.data routine) — no per-page entity request.
#
# Stale-URL allowlist: [action-required, in-progress, changes-required].
# Escape hatch: review's Edit-link sets _input: skip_status_redirect=true.
#
# Outer-card suppression rule: if action_config.form[0].component is `section`
# at build time, the first form entry renders its own Card (section is the only
# structural component that does) — drop the outer layout.card wrap to avoid the
# double-card nesting. All other first entries (including the other structural
# components controlled_list / box / label / file_upload, which emit no card) get
# the outer form_card, so the description, form body, and comment share one card.
#
# Layout (Part 56 addendum; Part 64): universal-fields chips + ✎ ride the title
# bar's page_actions; a bare workflow-closed banner sits above the working
# content, and the author-authored description renders as the form's first child
# (plain Markdown lead-in, prepended in both the carded and outer-chrome
# branches); the action bar is the shell's floating `actions` slot (not_required
# / progress / submit).
_ref:
  module: layout
  component: page
  vars:
    id:
      _var: page_ids.edit
    title:
      _var:
        key: page_config.title
        default: null
    type:
      _var: workflow_title
    description:
      _state: action.message
    breadcrumbs:
      _ref:
        path: components/action-breadcrumbs.yaml
        vars:
{%- if list_page_id %}
          entity_list_page_id: {{ list_page_id }}
          entity_list_title: "{{ list_title }}"
{%- else %}
          entity_list_page_id: null
          entity_list_title: null
{%- endif %}
          entity_title:
            _state: action.entity_link.title
          entity_name:
            _state: action.entity_link.name
          entity_page_id:
            _state: action.entity_link.pageId
          entity_url_query:
            _state: action.entity_link.urlQuery
          workflow_id:
            _state: action.workflow_id
          workflow_title:
            _var: workflow_title
          action_label:
            _var:
              key: page_config.title
              default: null
    status:
      _state: action.status.0.stage
    status_enum:
      _ref: ../shared/enums/action_statuses.yaml
    # Universal-fields chips (assignees avatars + due pill + ✎ → edit modal) in the
    # title bar's page_actions, only when the action declares universal fields.
    page_actions:
      _build.if:
        test:
          _build.gt:
            - _build.array.length:
                _var:
                  key: action_config.universal_fields
                  default: []
            - 0
        then:
          - _ref:
              path: components/universal-fields/universal-fields-chips.yaml
              vars:
                modal_id: universal_fields_edit_modal
                show:
                  _var: action_config.universal_fields
                assignee_docs: action.assignee_docs
                action_data:
                  due_date:
                    _state: action.due_date
                  stage:
                    _state: action.status.0.stage
        else: []
    show_back_button: true
    content_width:
      _var:
        key: page_config.maxWidth
        default: null
    requests:
      _build.array.concat:
        - - _ref: requests/get_workflow_action.yaml
        - _var:
            key: page_config.requests
            default: []
    events:
      onMount:
        _build.array.concat:
          - - id: redirect_no_action
              type: Link
              skip:
                _ne:
                  - _url_query: action_id
                  - null
              params:
                back: true
            - id: get_action
              type: Request
              params: get_workflow_action
            - id: set_action
              type: SetState
              params:
                action:
                  _request: get_workflow_action
            # Normalized entity id for the shell's columns.
            - id: set_entity_id
              type: SetState
              params:
                entity_id:
                  _request: get_workflow_action.entity.id
            # Closed-workflow guard: a closed (non-survivor) action is locked —
            # bounce to the read-only view before the stale-URL guard runs.
            # Ignores skip_status_redirect (closed is a harder stop than stale).
            - id: redirect_workflow_closed
              type: Link
              skip:
                _not:
                  _and:
                    - _state: action.workflow_closed
                    - _ne:
                        - _state: action.required_after_close
                        - true
              params:
                pageId:
                  _module.pageId:
                    _var: page_ids.view
                urlQuery:
                  _url_query: true
            # Stale-URL guard: skip when status is in the allowlist OR
            # when the caller (review's Edit-link) opted out.
            - id: redirect_stale_status
              type: Link
              skip:
                _or:
                  - _array.includes:
                      - - action-required
                        - in-progress
                        - changes-required
                      - _state: action.status.0.stage
                  - _eq:
                      - _input: skip_status_redirect
                      - true
              params:
                pageId:
                  _module.pageId:
                    _var: page_ids.view
                urlQuery:
                  _url_query: true
            - id: prime_form_state
              type: SetState
              params:
                form:
                  _state: action.form_values
                fields:
                  assignees:
                    _state: action.assignees
                  due_date:
                    _state: action.due_date
                comment: null
                comment_internal: false
          - _var:
              key: page_config.events.onMount
              default: []
    blocks:
      _build.array.concat:
        # Three-tier shell: left (entity workflows) + middle (closed banner +
        # form body with description lead-in + floating action bar) + RHS
        # (Details? above History). The middle body is wrapped in a Card unless
        # the first form entry is a `section` (which renders its own Card —
        # outer-card suppression on form[0].component == section).
        - - _ref:
              path: components/action-workspace.yaml
              vars:
                entity_connection_id:
                  _var: connection_id
                reference_field:
                  _var: reference_field
                details_slot:
                  _var: entity_view_slot
                middle:
                  _build.array.concat:
                    # Workflow-closed banner — bare full-width alert above the
                    # working content (Part 64 layout model; consistency fix).
                    # Gated on workflow_closed AND not required_after_close.
                    - - id: workflow_closed_banner
                        type: Alert
                        visible:
                          _and:
                            - _state: action.workflow_closed
                            - _ne:
                                - _state: action.required_after_close
                                - true
                        properties:
                          type: warning
                          showIcon: true
                          message: Workflow closed
                          description: This workflow is closed. Updates to this action are no longer accepted.
                    # Changes-requested callout — bare full-width alert below the
                    # closed banner, above the working content (Part 62). Self-hides
                    # unless the action is in changes-required with a brief.
                    - - _ref:
                          path: components/changes-requested-callout.yaml
                          vars:
                            content:
                              _state: action.changes_requested
                    - _build.if:
                        test:
                          _build.eq:
                            - _var:
                                key: action_config.form.0.component
                                default: null
                            - section
                        then:
                          # First form entry is a `section` — the only structural
                          # component that renders its own Card. It owns the outer
                          # chrome, so drop the outer form_card to avoid double-card
                          # nesting. Other structural components (controlled_list,
                          # box, label, file_upload) emit only a Box/Label with no
                          # card, so they fall through to the else branch and get
                          # wrapped like any other field.
                          # The description lead-in is prepended here too (it must
                          # land inside whichever container holds the form).
                          _build.array.concat:
                            - - _ref:
                                  path: components/action-description.yaml
                                  vars:
                                    content:
                                      _state: action.description
                            - _var:
                                key: page_config.formHeader
                                default: []
                            - _ref:
                                resolver: resolvers/makeActionsForm.js
                                vars:
                                  form:
                                    _var: action_config.form
                                  mode: edit
                            - - _ref:
                                  path: components/comment-input.yaml
                                  vars:
                                    comment_path: comment
                                    visibility_path: comment_internal
                                    placeholder: Add a comment (optional).
                            - _var:
                                key: page_config.formFooter
                                default: []
                        else:
                          # Default: wrap in a Card.
                          - id: form_card
                            type: Card
                            layout:
                              gap: 16
                            blocks:
                              _build.array.concat:
                                # Description lead-in — first child of the form
                                # card (plain Markdown; self-hides when unset).
                                - - _ref:
                                      path: components/action-description.yaml
                                      vars:
                                        content:
                                          _state: action.description
                                - _var:
                                    key: page_config.formHeader
                                    default: []
                                - _ref:
                                    resolver: resolvers/makeActionsForm.js
                                    vars:
                                      form:
                                        _var: action_config.form
                                      mode: edit
                                - - _ref:
                                      path: components/comment-input.yaml
                                      vars:
                                        comment_path: comment
                                        visibility_path: comment_internal
                                        placeholder: Add a comment (optional).
                                - _var:
                                    key: page_config.formFooter
                                    default: []
                # Floating action bar (shell `actions` slot): workflow extras on the
                # left, signal verbs on the right (grow spacer between).
                actions:
                  _build.array.concat:
                    - _var:
                        key: page_config.buttons.extra
                        default: []
                    - - id: action_bar_spacer
                        type: Box
                        layout:
                          flex: 1 1 0
                    - - id: button_not_required
                        type: Button
                        layout:
                          flex: 0 1 auto
                        visible:
                          _and:
                            - _var:
                                key: page_config.buttons.not_required.visible
                                default: true
                            - _state: action.buttons.not_required
                        properties:
                          title: Mark Not Required
                          type: default
                          disabled:
                            _or:
                              - _var:
                                  key: page_config.buttons.not_required.disabled
                                  default: false
                              - _and:
                                  - _state: action.workflow_closed
                                  - _ne:
                                      - _state: action.required_after_close
                                      - true
                        events:
                          onClick:
                            _build.if:
                              test:
                                _build.ne:
                                  - _var:
                                      key: page_config.buttons.not_required.modal
                                      default: null
                                  - null
                              then:
                                - id: open_not_required_modal
                                  type: CallMethod
                                  params:
                                    method: open
                                    blockId: not_required_modal
                              else:
                                _build.array.concat:
                                  - _var:
                                      key: page_config.events.onSubmit
                                      default: []
                                  - - id: submit_not_required
                                      type: CallAPI
                                      params:
                                        endpointId:
                                          _module.endpointId: {{ workflow_type }}-submit
                                        payload:
                                          action_id:
                                            _state: action._id
                                          signal: not_required
                                          current_key:
                                            _state: action.key
                                          comment:
                                            _state: comment
                                          comment_visibility:
                                            _if:
                                              test:
                                                _eq:
                                                  - _state: comment_internal
                                                  - true
                                              then: internal
                                              else: shared
                                  # Terminal signal — return to the entity on success.
                                  - _ref:
                                      path: components/return-to-entity.yaml
                                      vars:
                                        entity_page_id:
                                          _state: action.entity_link.pageId
                                        entity_url_query:
                                          _state: action.entity_link.urlQuery
                                        success_message:
                                          _var:
                                            key: page_config.buttons.not_required.successMessage
                                            default: Marked as not required.
                      - id: button_progress
                        type: Button
                        layout:
                          flex: 0 1 auto
                        visible:
                          _and:
                            - _var:
                                key: page_config.buttons.progress.visible
                                default: true
                            - _state: action.buttons.progress
                        properties:
                          title:
                            _var:
                              key: page_config.buttons.progress.title
                              default: Save Draft
                          type: default
                          disabled:
                            _or:
                              - _var:
                                  key: page_config.buttons.progress.disabled
                                  default: false
                              - _and:
                                  - _state: action.workflow_closed
                                  - _ne:
                                      - _state: action.required_after_close
                                      - true
                        events:
                          onClick:
                            _build.array.concat:
                              - _var:
                                  key: page_config.events.onProgress
                                  default: []
                              - - id: progress
                                  type: CallAPI
                                  params:
                                    endpointId:
                                      _module.endpointId: {{ workflow_type }}-submit
                                    payload:
                                      action_id:
                                        _state: action._id
                                      signal: progress
                                      current_key:
                                        _state: action.key
                                      form:
                                        _state: form
                                      comment:
                                        _state: comment
                                      comment_visibility:
                                        _if:
                                          test:
                                            _eq:
                                              - _state: comment_internal
                                              - true
                                          then: internal
                                          else: shared
                                # Progress succeeded (CallAPI halts the chain on
                                # error): refetch the action so status/key reflect
                                # the saved draft, then confirm with a toast.
                                - id: refetch_action_progress
                                  type: Request
                                  params: get_workflow_action
                                - id: reset_action_progress
                                  type: SetState
                                  params:
                                    action:
                                      _request: get_workflow_action
                                    # Clear the comment inputs after a successful
                                    # draft-save so the same comment is not folded
                                    # into another event on the next Save Draft
                                    # (parity with the check page's progress reseed).
                                    comment: null
                                    comment_internal: false
                                - id: progress_success_message
                                  type: DisplayMessage
                                  params:
                                    status: success
                                    content:
                                      _var:
                                        key: page_config.buttons.progress.successMessage
                                        default: Draft saved.
                      - id: button_submit
                        type: Button
                        layout:
                          flex: 0 1 auto
                        visible:
                          _and:
                            - _var:
                                key: page_config.buttons.submit.visible
                                default: true
                            - _state: action.buttons.submit
                        properties:
                          title:
                            _var:
                              key: page_config.buttons.submit.title
                              default: Submit
                          type: primary
                          disabled:
                            _or:
                              - _var:
                                  key: page_config.buttons.submit.disabled
                                  default: false
                              - _and:
                                  - _state: action.workflow_closed
                                  - _ne:
                                      - _state: action.required_after_close
                                      - true
                        events:
                          onClick:
                            _build.if:
                              test:
                                _build.ne:
                                  - _var:
                                      key: page_config.buttons.submit.modal
                                      default: null
                                  - null
                              then:
                                - id: open_submit_modal
                                  type: CallMethod
                                  params:
                                    method: open
                                    blockId: submit_modal
                              else:
                                _build.array.concat:
                                  - - id: validate
                                      type: Validate
                                      params:
                                        regex:
                                          - ^form\.
                                  - _var:
                                      key: page_config.events.onSubmit
                                      default: []
                                  - - id: submit
                                      type: CallAPI
                                      params:
                                        endpointId:
                                          _module.endpointId: {{ workflow_type }}-submit
                                        payload:
                                          action_id:
                                            _state: action._id
                                          signal: submit
                                          current_key:
                                            _state: action.key
                                          form:
                                            _state: form
                                          comment:
                                            _state: comment
                                          comment_visibility:
                                            _if:
                                              test:
                                                _eq:
                                                  - _state: comment_internal
                                                  - true
                                              then: internal
                                              else: shared
                                  # Submit succeeded (CallAPI halts the chain on
                                  # error): confirm, then return to the entity.
                                  - _ref:
                                      path: components/return-to-entity.yaml
                                      vars:
                                        entity_page_id:
                                          _state: action.entity_link.pageId
                                        entity_url_query:
                                          _state: action.entity_link.urlQuery
                                        success_message:
                                          _var:
                                            key: page_config.buttons.submit.successMessage
                                            default: Submitted successfully.
        # Universal-fields edit modal — opened by the title-bar ✎ chip.
        - _build.if:
            test:
              _build.gt:
                - _build.array.length:
                    _var:
                      key: action_config.universal_fields
                      default: []
                - 0
            then:
              - _ref:
                  path: components/universal-fields/universal-fields-modal.yaml
                  vars:
                    modal_id: universal_fields_edit_modal
                    state_path: fields
                    workflow_type: {{ workflow_type }}
                    action_id:
                      _state: action._id
                    allowed_edit:
                      _state: action.allowed.edit
                    show:
                      _var: action_config.universal_fields
                    on_complete:
                      - id: refetch_action_fields
                        type: Request
                        params: get_workflow_action
                      - id: reset_action_fields
                        type: SetState
                        params:
                          action:
                            _request: get_workflow_action
                      - id: update_fields_success
                        type: DisplayMessage
                        params:
                          status: success
                          content: Updated successfully.
            else: []
        # Confirm modals — render iff page_config.buttons.{name}.modal is set.
        - _build.if:
            test:
              _build.ne:
                - _var:
                    key: page_config.buttons.submit.modal
                    default: null
                - null
            then:
              - id: submit_modal
                type: ConfirmModal
                properties:
                  width: 600
                  title:
                    _var:
                      key: page_config.buttons.submit.modal.title
                      default: null
                  okText: Submit
                  content:
                    _var:
                      key: page_config.buttons.submit.modal.content
                      default: You are confirming your submission. Would you like to proceed?
                events:
                  onOk:
                    _build.array.concat:
                      - - id: validate
                          type: Validate
                          params:
                            regex:
                              - ^form\.
                      - _var:
                          key: page_config.events.onSubmit
                          default: []
                      - - id: submit
                          type: CallAPI
                          params:
                            endpointId:
                              _module.endpointId: {{ workflow_type }}-submit
                            payload:
                              action_id:
                                _state: action._id
                              signal: submit
                              current_key:
                                _state: action.key
                              form:
                                _state: form
                              comment:
                                _state: comment
                              comment_visibility:
                                _if:
                                  test:
                                    _eq:
                                      - _state: comment_internal
                                      - true
                                  then: internal
                                  else: shared
                      # Submit succeeded (CallAPI halts the chain on error):
                      # confirm, then return to the entity.
                      - _ref:
                          path: components/return-to-entity.yaml
                          vars:
                            entity_page_id:
                              _state: action.entity_link.pageId
                            entity_url_query:
                              _state: action.entity_link.urlQuery
                            success_message:
                              _var:
                                key: page_config.buttons.submit.successMessage
                                default: Submitted successfully.
            else: []
        - _build.if:
            test:
              _build.ne:
                - _var:
                    key: page_config.buttons.not_required.modal
                    default: null
                - null
            then:
              - id: not_required_modal
                type: ConfirmModal
                properties:
                  width: 600
                  title:
                    _var:
                      key: page_config.buttons.not_required.modal.title
                      default: null
                  okText: Mark Not Required
                  content:
                    _var:
                      key: page_config.buttons.not_required.modal.content
                      default: You are marking this action as not required. Would you like to proceed?
                events:
                  onOk:
                    _build.array.concat:
                      - _var:
                          key: page_config.events.onSubmit
                          default: []
                      - - id: submit_not_required
                          type: CallAPI
                          params:
                            endpointId:
                              _module.endpointId: {{ workflow_type }}-submit
                            payload:
                              action_id:
                                _state: action._id
                              signal: not_required
                              current_key:
                                _state: action.key
                              comment:
                                _state: comment
                              comment_visibility:
                                _if:
                                  test:
                                    _eq:
                                      - _state: comment_internal
                                      - true
                                  then: internal
                                  else: shared
                      # Terminal signal — return to the entity on success.
                      - _ref:
                          path: components/return-to-entity.yaml
                          vars:
                            entity_page_id:
                              _state: action.entity_link.pageId
                            entity_url_query:
                              _state: action.entity_link.urlQuery
                            success_message:
                              _var:
                                key: page_config.buttons.not_required.successMessage
                                default: Marked as not required.
            else: []
