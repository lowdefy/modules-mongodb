# Writable edit page for a form action.
#
# Build-time vars (from makeActionPages.js): action_config, page_config,
# page_ids, workflow_type, entity_collection. See view.yaml.njk for the
# full schema.
#
# Stale-URL allowlist: [action-required, in-progress, changes-required].
# Escape hatch: review's Edit-link sets _input: skip_status_redirect=true.
#
# Outer-card suppression rule (v0 parity): if action_config.form[0].form is
# truthy at build time, the first form entry owns its own outer chrome —
# drop the outer layout.card wrap to avoid the double-card nesting.
_ref:
  module: layout
  component: page
  vars:
    id:
      _var: page_ids.edit
    title:
      _var:
        key: page_config.title
        default: null
    show_back_button: true
    content_width:
      _var:
        key: page_config.maxWidth
        default: 750
    requests:
      _build.array.concat:
        - - _ref: requests/get_workflow_action.yaml
          - _ref:
              path: requests/get_entity.yaml.njk
              vars:
                entity_collection: {{ entity_collection }}
        - _var:
            key: page_config.requests
            default: []
    events:
      onMount:
        _build.array.concat:
          - - id: redirect_no_action
              type: Link
              skip:
                _ne:
                  - _url_query: action_id
                  - null
              params:
                back: true
            - id: get_action
              type: Request
              params: get_workflow_action
            - id: set_action
              type: SetState
              params:
                action:
                  _request: get_workflow_action
            # Stale-URL guard: skip when status is in the allowlist OR
            # when the caller (review's Edit-link) opted out.
            - id: redirect_stale_status
              type: Link
              skip:
                _or:
                  - _array.includes:
                      - - action-required
                        - in-progress
                        - changes-required
                      - _state: action.status.0.stage
                  - _eq:
                      - _input: skip_status_redirect
                      - true
              params:
                pageId:
                  _module.pageId:
                    _var: page_ids.view
                urlQuery:
                  _url_query: true
            - id: get_entity
              type: Request
              params: get_entity
            - id: prime_form_state
              type: SetState
              params:
                form:
                  _state: action.form_values
                fields:
                  assignees:
                    _state: action.assignees
                  due_date:
                    _state: action.due_date
                  description:
                    _state: action.description
                comment: null
          - _var:
              key: page_config.events.onMount
              default: []
    blocks:
      _build.array.concat:
        # Card-interior content — wrapped in layout.card unless the first
        # form entry owns its own outer chrome.
        - _build.if:
            test:
              _build.ne:
                - _var:
                    key: action_config.form.0.form
                    default: null
                - null
            then:
              # First form entry owns outer chrome — render content directly.
              _build.array.concat:
                - _var:
                    key: page_config.formHeader
                    default: []
                - - _ref:
                      path: components/universal-fields/universal-fields.yaml
                      vars:
                        mode: edit
                        kind: form
                        action_data:
                          assignees:
                            _state: fields.assignees
                          due_date:
                            _state: fields.due_date
                          description:
                            _state: fields.description
                - _ref:
                    resolver: resolvers/makeActionsForm.js
                    vars:
                      form:
                        _var: action_config.form
                      mode: edit
                - - id: comment
                    type: TiptapInput
                    properties:
                      title: Comment
                      placeholder: Add a comment (optional).
                - _var:
                    key: page_config.formFooter
                    default: []
            else:
              # Default: wrap in a Card.
              - id: form_card
                type: Card
                layout:
                  gap: 16
                blocks:
                  _build.array.concat:
                    - _var:
                        key: page_config.formHeader
                        default: []
                    - - _ref:
                          path: components/universal-fields/universal-fields.yaml
                          vars:
                            mode: edit
                            kind: form
                            action_data:
                              assignees:
                                _state: fields.assignees
                              due_date:
                                _state: fields.due_date
                              description:
                                _state: fields.description
                    - _ref:
                        resolver: resolvers/makeActionsForm.js
                        vars:
                          form:
                            _var: action_config.form
                          mode: edit
                    - - id: comment
                        type: TiptapInput
                        properties:
                          title: Comment
                          placeholder: Add a comment (optional).
                    - _var:
                        key: page_config.formFooter
                        default: []
        # Floating-actions sticky button bar.
        - - _ref:
              module: layout
              component: floating-actions
              vars:
                actions:
                  - id: button_not_required
                    type: Button
                    layout:
                      flex: 0 1 auto
                    visible:
                      _and:
                        - _var:
                            key: page_config.buttons.not_required.visible
                            default: true
                        - _state: action.buttons.not_required
                    properties:
                      title: Mark Not Required
                      type: default
                      disabled:
                        _var:
                          key: page_config.buttons.not_required.disabled
                          default: false
                    events:
                      onClick:
                        _build.if:
                          test:
                            _build.ne:
                              - _var:
                                  key: page_config.buttons.not_required.modal
                                  default: null
                              - null
                          then:
                            - id: open_not_required_modal
                              type: CallMethod
                              params:
                                method: open
                                blockId: not_required_modal
                          else:
                            _build.array.concat:
                              - _var:
                                  key: page_config.events.onSubmit
                                  default: []
                              - - id: submit_not_required
                                  type: CallAPI
                                  params:
                                    endpointId:
                                      _module.endpointId: {{ workflow_type }}-submit
                                    payload:
                                      action_id:
                                        _state: action._id
                                      signal: not_required
                                      current_key:
                                        _state: action.key
                                      comment:
                                        _state: comment
                  - id: button_progress
                    type: Button
                    layout:
                      flex: 0 1 auto
                    visible:
                      _and:
                        - _var:
                            key: page_config.buttons.progress.visible
                            default: true
                        - _state: action.buttons.progress
                    properties:
                      title: Save Draft
                      type: default
                      disabled:
                        _var:
                          key: page_config.buttons.progress.disabled
                          default: false
                    events:
                      onClick:
                        _build.array.concat:
                          - _var:
                              key: page_config.events.onProgress
                              default: []
                          - - id: progress
                              type: CallAPI
                              params:
                                endpointId:
                                  _module.endpointId: {{ workflow_type }}-submit
                                payload:
                                  action_id:
                                    _state: action._id
                                  signal: progress
                                  current_key:
                                    _state: action.key
                                  form:
                                    _state: form
                  - id: button_submit
                    type: Button
                    layout:
                      flex: 0 1 auto
                    visible:
                      _and:
                        - _var:
                            key: page_config.buttons.submit.visible
                            default: true
                        - _state: action.buttons.submit
                    properties:
                      title: Submit
                      type: primary
                      disabled:
                        _var:
                          key: page_config.buttons.submit.disabled
                          default: false
                    events:
                      onClick:
                        _build.if:
                          test:
                            _build.ne:
                              - _var:
                                  key: page_config.buttons.submit.modal
                                  default: null
                              - null
                          then:
                            - id: open_submit_modal
                              type: CallMethod
                              params:
                                method: open
                                blockId: submit_modal
                          else:
                            _build.array.concat:
                              - - id: validate
                                  type: Validate
                                  params:
                                    regex:
                                      - ^form\.
                              - _var:
                                  key: page_config.events.onSubmit
                                  default: []
                              - - id: submit
                                  type: CallAPI
                                  params:
                                    endpointId:
                                      _module.endpointId: {{ workflow_type }}-submit
                                    payload:
                                      action_id:
                                        _state: action._id
                                      signal: submit
                                      current_key:
                                        _state: action.key
                                      form:
                                        _state: form
                                      comment:
                                        _state: comment
        # Confirm modals — render iff page_config.buttons.{name}.modal is set.
        - _build.if:
            test:
              _build.ne:
                - _var:
                    key: page_config.buttons.submit.modal
                    default: null
                - null
            then:
              - id: submit_modal
                type: ConfirmModal
                properties:
                  width: 600
                  title:
                    _var:
                      key: page_config.buttons.submit.modal.title
                      default: null
                  okText: Submit
                  content:
                    _var:
                      key: page_config.buttons.submit.modal.content
                      default: You are confirming your submission. Would you like to proceed?
                events:
                  onOk:
                    _build.array.concat:
                      - - id: validate
                          type: Validate
                          params:
                            regex:
                              - ^form\.
                      - _var:
                          key: page_config.events.onSubmit
                          default: []
                      - - id: submit
                          type: CallAPI
                          params:
                            endpointId:
                              _module.endpointId: {{ workflow_type }}-submit
                            payload:
                              action_id:
                                _state: action._id
                              signal: submit
                              current_key:
                                _state: action.key
                              form:
                                _state: form
                              comment:
                                _state: comment
            else: []
        - _build.if:
            test:
              _build.ne:
                - _var:
                    key: page_config.buttons.not_required.modal
                    default: null
                - null
            then:
              - id: not_required_modal
                type: ConfirmModal
                properties:
                  width: 600
                  title:
                    _var:
                      key: page_config.buttons.not_required.modal.title
                      default: null
                  okText: Mark Not Required
                  content:
                    _var:
                      key: page_config.buttons.not_required.modal.content
                      default: You are marking this action as not required. Would you like to proceed?
                events:
                  onOk:
                    _build.array.concat:
                      - _var:
                          key: page_config.events.onSubmit
                          default: []
                      - - id: submit_not_required
                          type: CallAPI
                          params:
                            endpointId:
                              _module.endpointId: {{ workflow_type }}-submit
                            payload:
                              action_id:
                                _state: action._id
                              signal: not_required
                              current_key:
                                _state: action.key
                              comment:
                                _state: comment
            else: []
