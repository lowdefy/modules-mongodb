# Read-only view page for a form action.
#
# Build-time vars (from makeActionPages.js):
#   action_config: { type, kind, key, tracker, blocked_by, action_group,
#                    required_after_close, access, status_map,
#                    form, form_review, form_error, hooks, interactions, event }
#   page_config:   per-verb chrome lifted from action.pages.view
#                  ({ title, requests, events, formHeader, formFooter,
#                     modals, maxWidth, buttons }), defaults to {}.
#   page_ids:      { view, edit?, review?, error? }
#   workflow_type: workflow.type
#   connection_id: workflow.entity.connection_id (the actions-on-entity panel's connection)
#   workflow_title: baked workflow-title string (eyebrow + breadcrumb workflow label)
#   reference_field: baked entity.ref_key string (History match field)
#   entity_view_slot: baked block array from workflow.entity_view.slot (may be [])
#
# Part 26: the entity instance name + entity fields arrive on the single
# get_workflow_action response (entity_link.name + the entity object), resolved
# server-side from the workflow's entity.data routine — no per-page entity request.
#
# Layout (Part 56 addendum; Part 64): universal-fields chips + ✎ ride the title
# bar's page_actions; a bare workflow-closed banner sits above the form card, and
# the author-authored description renders as the form card's first child (plain
# Markdown lead-in); the action bar is the shell's floating `actions` slot (Edit
# nav + request_changes here). No stale-URL guard.
_ref:
  module: layout
  component: page
  vars:
    id:
      _var: page_ids.view
    title:
      _var:
        key: page_config.title
        default: null
    type:
      _var: workflow_title
    description:
      _state: action.message
    breadcrumbs:
      _ref:
        path: components/action-breadcrumbs.yaml
        vars:
{%- if list_page_id %}
          entity_list_page_id: {{ list_page_id }}
          entity_list_title: "{{ list_title }}"
{%- else %}
          entity_list_page_id: null
          entity_list_title: null
{%- endif %}
          entity_title:
            _state: action.entity_link.title
          entity_name:
            _state: action.entity_link.name
          entity_page_id:
            _state: action.entity_link.pageId
          entity_url_query:
            _state: action.entity_link.urlQuery
          workflow_id:
            _state: action.workflow_id
          workflow_title:
            _var: workflow_title
          action_label:
            _var:
              key: page_config.title
              default: null
    status:
      _state: action.status.0.stage
    status_enum:
      _ref: ../shared/enums/action_statuses.yaml
    # Universal-fields chips (assignees avatars + due pill + ✎ → edit modal) in the
    # title bar's page_actions, only when the action declares universal fields.
    page_actions:
      _build.if:
        test:
          _build.gt:
            - _build.array.length:
                _var:
                  key: action_config.universal_fields
                  default: []
            - 0
        then:
          - _ref:
              path: components/universal-fields/universal-fields-chips.yaml
              vars:
                modal_id: universal_fields_edit_modal
                show:
                  _var: action_config.universal_fields
                action_data:
                  assignee_docs:
                    _state: action.assignee_docs
                  due_date:
                    _state: action.due_date
        else: []
    show_back_button: true
    content_width:
      _var:
        key: page_config.maxWidth
        default: null
    requests:
      _build.array.concat:
        - - _ref: requests/get_workflow_action.yaml
        - _var:
            key: page_config.requests
            default: []
    events:
      onMount:
        _build.array.concat:
          - # Step 1: action_id presence guard.
            - id: redirect_no_action
              type: Link
              skip:
                _ne:
                  - _url_query: action_id
                  - null
              params:
                back: true
            # Step 2: load the action.
            - id: get_action
              type: Request
              params: get_workflow_action
            - id: set_action
              type: SetState
              params:
                action:
                  _request: get_workflow_action
            # Normalized entity id for the shell's columns.
            - id: set_entity_id
              type: SetState
              params:
                entity_id:
                  _request: get_workflow_action.entity.id
            # Step 3 (stale-URL guard) — intentionally omitted on view.
            # Step 4: prime form state from envelope's form_values.
            - id: prime_form_state
              type: SetState
              params:
                form:
                  _state: action.form_values
                fields:
                  assignees:
                    _state: action.assignees
                  due_date:
                    _state: action.due_date
                change_request_comment: null
          # Step 8: author-supplied onMount runs last.
          - _var:
              key: page_config.events.onMount
              default: []
    blocks:
      _build.array.concat:
        # Three-tier shell: left (entity workflows) + middle (closed banner +
        # form card with description lead-in + floating action bar) + RHS
        # (Details? above History).
        - - _ref:
              path: components/action-workspace.yaml
              vars:
                entity_connection_id:
                  _var: connection_id
                reference_field:
                  _var: reference_field
                details_slot:
                  _var: entity_view_slot
                middle:
                  _build.array.concat:
                    # Workflow-closed banner — bare full-width alert above the
                    # content card (Part 64 layout model; the form pages gain it
                    # for consistency with the check page). Gated on
                    # workflow_closed AND not required_after_close.
                    - - id: workflow_closed_banner
                        type: Alert
                        visible:
                          _and:
                            - _state: action.workflow_closed
                            - _ne:
                                - _state: action.required_after_close
                                - true
                        properties:
                          type: warning
                          showIcon: true
                          message: Workflow closed
                          description: This workflow is closed. Updates to this action are no longer accepted.
                    # Changes-requested callout — bare full-width alert below the
                    # closed banner, above the content card (Part 62). Self-hides
                    # unless the action is in changes-required with a brief.
                    - - _ref:
                          path: components/changes-requested-callout.yaml
                          vars:
                            content:
                              _state: action.changes_requested
                    - - id: form_card
                        type: Card
                        layout:
                          gap: 16
                        blocks:
                          _build.array.concat:
                            # Description lead-in — first child of the form card
                            # (plain Markdown; self-hides when unset).
                            - - _ref:
                                  path: components/action-description.yaml
                                  vars:
                                    content:
                                      _state: action.description
                            - _var:
                                key: page_config.formHeader
                                default: []
                            - - id: form_body
                                type: DataDescriptions
                                properties:
                                  formConfig:
                                    _var: action_config.form
                                  data:
                                    form:
                                      _state: form
                                    entity:
                                      _request: get_workflow_action.entity
                            - _var:
                                key: page_config.formFooter
                                default: []
                # Floating action bar (shell `actions` slot): workflow extras on the
                # left, signal verbs on the right (grow spacer between).
                actions:
                  _build.array.concat:
                    - _var:
                        key: page_config.buttons.extra
                        default: []
                    - - id: action_bar_spacer
                        type: Box
                        layout:
                          flex: 1 1 0
                    - - id: button_request_changes
                        type: Button
                        layout:
                          flex: 0 1 auto
                        visible:
                          _and:
                            - _var:
                                key: page_config.buttons.request_changes.visible
                                default: false
                            - _state: action.buttons.request_changes
                        properties:
                          title: Request Changes
                          type: default
                          danger: true
                          ghost: true
                          disabled:
                            _var:
                              key: page_config.buttons.request_changes.disabled
                              default: false
                        events:
                          onClick:
                            - id: open_request_changes_modal
                              type: CallMethod
                              params:
                                method: open
                                blockId: request_changes_modal
                      # Edit (navigation) — not gated on action_allowed; edit page
                      # gates its own writes. Sets skip_status_redirect so edit's
                      # stale-URL guard lets `done` actions through to re-open.
                      - id: button_edit
                        type: Button
                        layout:
                          flex: 0 1 auto
                        visible:
                          _var:
                            key: page_config.buttons.edit.visible
                            default:
                              _build.ne:
                                - _var:
                                    key: page_ids.edit
                                    default: null
                                - null
                        properties:
                          title: Edit
                          type: default
                          disabled:
                            _var:
                              key: page_config.buttons.edit.disabled
                              default: false
                        events:
                          onClick:
                            - id: link_edit
                              type: Link
                              params:
                                pageId:
                                  _module.pageId:
                                    _var: page_ids.edit
                                urlQuery:
                                  _url_query: true
                                input:
                                  skip_status_redirect: true
        # Universal-fields edit modal — opened by the title-bar ✎ chip.
        - _build.if:
            test:
              _build.gt:
                - _build.array.length:
                    _var:
                      key: action_config.universal_fields
                      default: []
                - 0
            then:
              - _ref:
                  path: components/universal-fields/universal-fields-modal.yaml
                  vars:
                    modal_id: universal_fields_edit_modal
                    state_path: fields
                    workflow_type: {{ workflow_type }}
                    action_id:
                      _state: action._id
                    allowed_edit:
                      _state: action.allowed.edit
                    show:
                      _var: action_config.universal_fields
                    on_complete:
                      - id: refetch_action_fields
                        type: Request
                        params: get_workflow_action
                      - id: reset_action_fields
                        type: SetState
                        params:
                          action:
                            _request: get_workflow_action
                      - id: update_fields_success
                        type: DisplayMessage
                        params:
                          status: success
                          content: Updated successfully.
            else: []
        # Mandatory Request Changes modal — carries the required comment input.
        - - id: request_changes_modal
            type: Modal
            properties:
              width: 600
              title: Request Changes
              maskClosable: false
              okText: Request Changes
            events:
              onOk:
                _build.array.concat:
                  - - id: validate
                      type: Validate
                      params: change_request_comment
                  - _var:
                      key: page_config.events.onRequestChanges
                      default: []
                  - - id: submit_request_changes
                      type: CallAPI
                      params:
                        endpointId:
                          _module.endpointId: {{ workflow_type }}-submit
                        payload:
                          action_id:
                            _state: action._id
                          signal: request_changes
                          current_key:
                            _state: action.key
                          form:
                            _state: form
                          comment:
                            _state: change_request_comment
              onClose:
                - id: reset_comment
                  type: SetState
                  params:
                    change_request_comment: null
            blocks:
              - id: change_request_comment
                type: TiptapInput
                required: true
                validate:
                  - message: A comment is required to request changes
                    status: error
                    pass:
                      _ne:
                        - _if_none:
                            - _state: change_request_comment.text
                            - null
                        - null
                properties:
                  # Text-only (Part 62): disable the inline Image extension and
                  # leave s3PostPolicyRequestId unset, so the comment never
                  # carries a fileList / inline <img> — the callout that surfaces
                  # this brief only ever renders text.
                  image:
                    disabled: true
                  title: Change Description
                  placeholder: Please provide a description of the changes you would like.
