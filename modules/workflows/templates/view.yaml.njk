# Read-only view page for a form action.
#
# Build-time vars (from makeActionPages.js):
#   action_config: { type, kind, key, tracker, blocked_by, action_group,
#                    sort_order, required_after_close, access, status_map,
#                    form, form_review, form_error, hooks, interactions, event }
#   page_config:   per-verb chrome lifted from action.pages.view
#                  ({ title, requests, events, formHeader, formFooter,
#                     modals, maxWidth, buttons }), defaults to {}.
#   page_ids:      { view, edit?, review?, error? }
#   workflow_type: workflow.type
#   entity_collection: workflow.entity_collection (connection id baked into get_entity)
#
# View is read-only — no buttons, no stale-URL guard, no outer-card suppression.
_ref:
  module: layout
  component: page
  vars:
    id:
      _var: page_ids.view
    title:
      _var:
        key: page_config.title
        default: null
    hide_title: true
    content_width:
      _var:
        key: page_config.maxWidth
        default: 750
    requests:
      _build.array.concat:
        - - _ref: requests/get_action.yaml
          - _ref: requests/get_workflow.yaml
          - _ref:
              path: requests/get_entity.yaml.njk
              vars:
                entity_collection: {{ entity_collection }}
        - _var:
            key: page_config.requests
            default: []
    events:
      onMount:
        _build.array.concat:
          - # Step 1: action_id presence guard.
            - id: redirect_no_action
              type: Link
              skip:
                _ne:
                  - _url_query: action_id
                  - null
              params:
                back: true
            # Step 2: load the action.
            - id: get_action
              type: Request
              params: get_action
            # Step 3 (stale-URL guard) — intentionally omitted on view.
            # Step 4: load the parent workflow (form_data lives here).
            - id: get_workflow
              type: Request
              params: get_workflow
            # Step 5: load the entity.
            - id: get_entity
              type: Request
              params: get_entity
            # Step 6: role check — sets _state.action_allowed.
            - _ref:
                path: components/action_role_check.yaml
                vars:
                  action_config:
                    _var: action_config
            # Step 7: prime form state from workflow.form_data.{action_type}.
            - id: prime_form_state
              type: SetState
              params:
                form:
                  _request:
                    _string.concat:
                      - get_workflow.form_data.
                      - _var: action_config.type
                fields:
                  assignees:
                    _request: get_action.assignees
                  due_date:
                    _request: get_action.due_date
                  description:
                    _request: get_action.description
          # Step 8: author-supplied onMount runs last.
          - _var:
              key: page_config.events.onMount
              default: []
    blocks:
      - id: form_card
        type: Card
        layout:
          gap: 16
        blocks:
          _build.array.concat:
            - _var:
                key: page_config.formHeader
                default: []
            - - _ref:
                  path: components/universal-fields/universal-fields.yaml
                  vars:
                    mode: display
                    kind: form
                    action_data:
                      assignees:
                        _request: get_action.assignees
                      due_date:
                        _request: get_action.due_date
                      description:
                        _request: get_action.description
            - - id: form_body
                type: DataDescriptions
                properties:
                  formConfig:
                    _var: action_config.form
                  data:
                    form:
                      _state: form
                    entity:
                      _request: get_entity
            - _var:
                key: page_config.formFooter
                default: []
