# Review page for a form action — read-only main form + writable form_review.
#
# Build-time vars (from makeActionPages.js): action_config, page_config,
# page_ids, workflow_type, entity_collection. See view.yaml.njk.
#
# Stale-URL allowlist: [in-review, error]. `error` is included so reviewers
# can see the action while it's mid-recovery; the engine-side recovery flow
# handles the actual transition.
#
# Three buttons: Edit (navigation, leftmost), Request Changes (danger),
# Approve (primary). Edit-link sets `skip_status_redirect: true` so the
# edit page's stale-URL guard doesn't bounce reviewers out of `in-review`.
_ref:
  module: layout
  component: page
  vars:
    id:
      _var: page_ids.review
    title:
      _var:
        key: page_config.title
        default: null
    show_back_button: true
    content_width:
      _var:
        key: page_config.maxWidth
        default: 750
    requests:
      _build.array.concat:
        - - _ref: requests/get_workflow_action.yaml
          - _ref:
              path: requests/get_entity.yaml.njk
              vars:
                entity_collection: {{ entity_collection }}
        - _var:
            key: page_config.requests
            default: []
    events:
      onMount:
        _build.array.concat:
          - - id: redirect_no_action
              type: Link
              skip:
                _ne:
                  - _url_query: action_id
                  - null
              params:
                back: true
            - id: get_action
              type: Request
              params: get_workflow_action
            - id: set_action
              type: SetState
              params:
                action:
                  _request: get_workflow_action
            - id: redirect_stale_status
              type: Link
              skip:
                _array.includes:
                  - - in-review
                    - error
                  - _state: action.status.0.stage
              params:
                pageId:
                  _module.pageId:
                    _var: page_ids.view
                urlQuery:
                  _url_query: true
            - id: get_entity
              type: Request
              params: get_entity
            - id: prime_form_state
              type: SetState
              params:
                form:
                  _state: action.form_values
                form_review:
                  _state: action.form_values
                fields:
                  assignees:
                    _state: action.assignees
                  due_date:
                    _state: action.due_date
                  description:
                    _state: action.description
                comment: null
                change_request_comment: null
          - _var:
              key: page_config.events.onMount
              default: []
    blocks:
      _build.array.concat:
        # Two-column content row: review body (left) + read-only
        # universal-fields sidebar (right), gated on universal_fields non-empty.
        # Reviewers who need to change metadata use the edit page's sidebar.
        - - id: action_content_row
            type: Box
            layout:
              gap: 16
            blocks:
              _build.array.concat:
                - - id: form_column
                    type: Box
                    layout:
                      span:
                        _build.if:
                          test:
                            _build.gt:
                              - _array.length:
                                  _var:
                                    key: action_config.universal_fields
                                    default: []
                              - 0
                          then: 16
                          else: 24
                      sm:
                        span: 24
                    blocks:
                      - id: review_card
                        type: Card
                        layout:
                          gap: 16
                        blocks:
                          _build.array.concat:
                            - _var:
                                key: page_config.formHeader
                                default: []
                            - - id: form_body
                                type: DataDescriptions
                                properties:
                                  formConfig:
                                    _var: action_config.form
                                  data:
                                    form:
                                      _state: form
                                    entity:
                                      _request: get_entity
                            # Writable form_review section — only renders when the
                            # action has a form_review schema declared.
                            - _build.if:
                                test:
                                  _build.gt:
                                    - _build.array.length:
                                        _var:
                                          key: action_config.form_review
                                          default: []
                                    - 0
                                then:
                                  - id: form_review_section
                                    type: Box
                                    visible:
                                      _and:
                                        - _eq:
                                            - _state: action.status.0.stage
                                            - in-review
                                        - _state: action.allowed.review
                                    blocks:
                                      _build.array.concat:
                                        - - id: form_review_divider
                                            type: Divider
                                            properties:
                                              title: Review
                                        - _ref:
                                            resolver: resolvers/makeActionsForm.js
                                            vars:
                                              form:
                                                _var: action_config.form_review
                                              mode: review
                                else: []
                            - - id: comment
                                type: TiptapInput
                                properties:
                                  title: Comment
                                  placeholder: Add a comment (optional).
                            - _var:
                                key: page_config.formFooter
                                default: []
                - _build.if:
                    test:
                      _build.gt:
                        - _array.length:
                            _var:
                              key: action_config.universal_fields
                              default: []
                        - 0
                    then:
                      - id: sidebar_column
                        type: Box
                        layout:
                          span: 8
                          sm:
                            span: 24
                        blocks:
                          - _ref:
                              path: components/universal-fields/universal-fields.yaml
                              vars:
                                mode: display
                                kind: form
                                state_path: fields
                                workflow_type: {{ workflow_type }}
                                show:
                                  _var: action_config.universal_fields
                                action_data:
                                  assignees:
                                    _state: action.assignees
                                  assignee_docs:
                                    _state: action.assignee_docs
                                  due_date:
                                    _state: action.due_date
                                  description:
                                    _state: action.description
                    else: []
        # Floating-actions sticky button bar.
        - - _ref:
              module: layout
              component: floating-actions
              vars:
                actions:
                  # Edit (navigation) — not gated on action_allowed; edit page
                  # gates its own writes. Always sets skip_status_redirect so
                  # edit's stale-URL guard lets `in-review` actions through.
                  - id: button_edit
                    type: Button
                    layout:
                      flex: 0 1 auto
                    visible:
                      _var:
                        key: page_config.buttons.edit.visible
                        default:
                          _build.ne:
                            - _var:
                                key: page_ids.edit
                                default: null
                            - null
                    properties:
                      title: Edit
                      type: default
                      disabled:
                        _var:
                          key: page_config.buttons.edit.disabled
                          default: false
                    events:
                      onClick:
                        - id: link_edit
                          type: Link
                          params:
                            pageId:
                              _module.pageId:
                                _var: page_ids.edit
                            urlQuery:
                              _url_query: true
                            input:
                              skip_status_redirect: true
                  - id: button_request_changes
                    type: Button
                    layout:
                      flex: 0 1 auto
                    visible:
                      _and:
                        - _var:
                            key: page_config.buttons.request_changes.visible
                            default: true
                        - _state: action.buttons.request_changes
                    properties:
                      title: Request Changes
                      type: default
                      danger: true
                      ghost: true
                      disabled:
                        _var:
                          key: page_config.buttons.request_changes.disabled
                          default: false
                    events:
                      onClick:
                        - id: open_request_changes_modal
                          type: CallMethod
                          params:
                            method: open
                            blockId: request_changes_modal
                  - id: button_approve
                    type: Button
                    layout:
                      flex: 0 1 auto
                    visible:
                      _and:
                        - _var:
                            key: page_config.buttons.approve.visible
                            default: true
                        - _state: action.buttons.approve
                    properties:
                      title: Approve
                      type: primary
                      disabled:
                        _var:
                          key: page_config.buttons.approve.disabled
                          default: false
                    events:
                      onClick:
                        _build.if:
                          test:
                            _build.ne:
                              - _var:
                                  key: page_config.buttons.approve.modal
                                  default: null
                              - null
                          then:
                            - id: open_approve_modal
                              type: CallMethod
                              params:
                                method: open
                                blockId: approve_modal
                          else:
                            _build.array.concat:
                              - - id: validate
                                  type: Validate
                                  params:
                                    regex:
                                      - ^form_review\.
                              - _var:
                                  key: page_config.events.onApprove
                                  default: []
                              - - id: submit_approve
                                  type: CallAPI
                                  params:
                                    endpointId:
                                      _module.endpointId: {{ workflow_type }}-submit
                                    payload:
                                      action_id:
                                        _state: action._id
                                      signal: approve
                                      current_key:
                                        _state: action.key
                                      form:
                                        _state: form
                                      form_review:
                                        _state: form_review
                                      comment:
                                        _state: comment
        # Mandatory Request Changes modal — carries the required comment input.
        - - id: request_changes_modal
            type: Modal
            properties:
              width: 600
              title: Request Changes
              maskClosable: false
              okText: Request Changes
            events:
              onOk:
                _build.array.concat:
                  - - id: validate
                      type: Validate
                      params: change_request_comment
                  - _var:
                      key: page_config.events.onRequestChanges
                      default: []
                  - - id: submit_request_changes
                      type: CallAPI
                      params:
                        endpointId:
                          _module.endpointId: {{ workflow_type }}-submit
                        payload:
                          action_id:
                            _state: action._id
                          signal: request_changes
                          current_key:
                            _state: action.key
                          form:
                            _state: form
                          form_review:
                            _state: form_review
                          comment:
                            _state: change_request_comment
              onClose:
                - id: reset_comment
                  type: SetState
                  params:
                    change_request_comment: null
            blocks:
              - id: change_request_comment
                type: TiptapInput
                required: true
                validate:
                  - message: A comment is required to request changes
                    status: error
                    pass:
                      _ne:
                        - _state: change_request_comment
                        - null
                properties:
                  title: Change Description
                  placeholder: Please provide a description of the changes you would like.
        # Optional Approve modal — renders iff page_config.buttons.approve.modal is set.
        - _build.if:
            test:
              _build.ne:
                - _var:
                    key: page_config.buttons.approve.modal
                    default: null
                - null
            then:
              - id: approve_modal
                type: ConfirmModal
                properties:
                  width: 600
                  title:
                    _var:
                      key: page_config.buttons.approve.modal.title
                      default: null
                  okText: Approve
                  content:
                    _var:
                      key: page_config.buttons.approve.modal.content
                      default: You are approving this action. Would you like to proceed?
                events:
                  onOk:
                    _build.array.concat:
                      - - id: validate
                          type: Validate
                          params:
                            regex:
                              - ^form_review\.
                      - _var:
                          key: page_config.events.onApprove
                          default: []
                      - - id: submit_approve
                          type: CallAPI
                          params:
                            endpointId:
                              _module.endpointId: {{ workflow_type }}-submit
                            payload:
                              action_id:
                                _state: action._id
                              signal: approve
                              current_key:
                                _state: action.key
                              form:
                                _state: form
                              form_review:
                                _state: form_review
                              comment:
                                _state: comment
            else: []
