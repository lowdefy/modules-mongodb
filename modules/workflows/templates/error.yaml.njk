# Error recovery page for a form action.
#
# Build-time vars (from makeActionPages.js): action_config, page_config,
# page_ids, workflow_type, connection_id, workflow_title, reference_field,
# entity_view_slot. See view.yaml.njk. The entity instance name arrives on
# get_workflow_action.entity_link.name (Part 26, from the workflow's entity.data
# routine) — no per-page entity request.
#
# Stale-URL allowlist: [error]. Only renders during recovery; any other
# stage redirects to -view.
#
# Outer-card suppression checks action_config.form_error[0].form (not
# `form` — error has its own form schema).
#
# The `resolve_error` button is the only interaction button whose `title`
# is overridable per app (default "Resolve").
#
# Layout (Part 56 addendum; Part 64): universal-fields chips + ✎ ride the title
# bar's page_actions; a bare workflow-closed banner sits above the working
# content, and the author-authored description renders as the recovery
# container's first child (plain Markdown lead-in, above the failure banner,
# prepended in both the carded and outer-chrome branches); the action bar is the
# shell's floating `actions` slot (single resolve_error button).
_ref:
  module: layout
  component: page
  vars:
    id:
      _var: page_ids.error
    title:
      _var:
        key: page_config.title
        default: null
    type:
      _var: workflow_title
    description:
      _state: action.message
    breadcrumbs:
      _ref:
        path: components/action-breadcrumbs.yaml
        vars:
{%- if list_page_id %}
          entity_list_page_id: {{ list_page_id }}
          entity_list_title: "{{ list_title }}"
{%- else %}
          entity_list_page_id: null
          entity_list_title: null
{%- endif %}
          entity_title:
            _state: action.entity_link.title
          entity_name:
            _state: action.entity_link.name
          entity_page_id:
            _state: action.entity_link.pageId
          entity_url_query:
            _state: action.entity_link.urlQuery
          workflow_id:
            _state: action.workflow_id
          workflow_title:
            _var: workflow_title
          action_label:
            _var:
              key: page_config.title
              default: null
    status:
      _state: action.status.0.stage
    status_enum:
      _ref: ../shared/enums/action_statuses.yaml
    # Universal-fields chips (assignees avatars + due pill + ✎ → edit modal) in the
    # title bar's page_actions, only when the action declares universal fields.
    page_actions:
      _build.if:
        test:
          _build.gt:
            - _build.array.length:
                _var:
                  key: action_config.universal_fields
                  default: []
            - 0
        then:
          - _ref:
              path: components/universal-fields/universal-fields-chips.yaml
              vars:
                modal_id: universal_fields_edit_modal
                show:
                  _var: action_config.universal_fields
                action_data:
                  assignee_docs:
                    _state: action.assignee_docs
                  due_date:
                    _state: action.due_date
        else: []
    show_back_button: true
    content_width:
      _var:
        key: page_config.maxWidth
        default: null
    requests:
      _build.array.concat:
        - - _ref: requests/get_workflow_action.yaml
        - _var:
            key: page_config.requests
            default: []
    events:
      onMount:
        _build.array.concat:
          - - id: redirect_no_action
              type: Link
              skip:
                _ne:
                  - _url_query: action_id
                  - null
              params:
                back: true
            - id: get_action
              type: Request
              params: get_workflow_action
            - id: set_action
              type: SetState
              params:
                action:
                  _request: get_workflow_action
            # Normalized entity id for the shell's columns.
            - id: set_entity_id
              type: SetState
              params:
                entity_id:
                  _request: get_workflow_action.entity.id
            - id: redirect_stale_status
              type: Link
              skip:
                _eq:
                  - _state: action.status.0.stage
                  - error
              params:
                pageId:
                  _module.pageId:
                    _var: page_ids.view
                urlQuery:
                  _url_query: true
            - id: prime_form_state
              type: SetState
              params:
                form:
                  _state: action.form_values
                fields:
                  assignees:
                    _state: action.assignees
                  due_date:
                    _state: action.due_date
                comment: null
                comment_internal: false
          - _var:
              key: page_config.events.onMount
              default: []
    blocks:
      _build.array.concat:
        # Three-tier shell: left (entity workflows) + middle (closed banner +
        # error/recovery body with description lead-in + floating action bar) +
        # RHS (Details? above History). Outer-card suppression on
        # form_error[0].form.
        - - _ref:
              path: components/action-workspace.yaml
              vars:
                entity_connection_id:
                  _var: connection_id
                reference_field:
                  _var: reference_field
                details_slot:
                  _var: entity_view_slot
                middle:
                  _build.array.concat:
                    # Workflow-closed banner — bare full-width alert above the
                    # working content (Part 64 layout model; consistency fix).
                    # Gated on workflow_closed AND not required_after_close.
                    - - id: workflow_closed_banner
                        type: Alert
                        visible:
                          _and:
                            - _state: action.workflow_closed
                            - _ne:
                                - _state: action.required_after_close
                                - true
                        properties:
                          type: warning
                          showIcon: true
                          message: Workflow closed
                          description: This workflow is closed. Updates to this action are no longer accepted.
                    # Changes-requested callout — bare full-width alert below the
                    # closed banner, above the working content (Part 62). Self-hides
                    # unless the action is in changes-required with a brief.
                    - - _ref:
                          path: components/changes-requested-callout.yaml
                          vars:
                            content:
                              _state: action.changes_requested
                    - _build.if:
                        test:
                          _build.ne:
                            - _var:
                                key: action_config.form_error.0.form
                                default: null
                            - null
                        then:
                          # First form entry owns outer chrome — render directly.
                          # The description lead-in is prepended here too (it must
                          # land inside whichever container holds the form).
                          _build.array.concat:
                            - - _ref:
                                  path: components/action-description.yaml
                                  vars:
                                    content:
                                      _state: action.description
                            - - id: failure_banner
                                type: Alert
                                properties:
                                  type: error
                                  showIcon: true
                                  message:
                                    _state: action.status.0.error_message
                                  description:
                                    _nunjucks:
                                      template: |
                                        <pre>{{ metadata }}</pre>
                                      on:
                                        metadata:
                                          _js:
                                            args:
                                              metadata:
                                                _state: action.status.0.error_metadata
                                            fn: |
                                              const { metadata } = args;
                                              return JSON.stringify(metadata, null, 2);
                            - _var:
                                key: page_config.formHeader
                                default: []
                            - _ref:
                                resolver: resolvers/makeActionsForm.js
                                vars:
                                  form:
                                    _var:
                                      key: action_config.form_error
                                      default: []
                                  mode: error
                            - - _ref:
                                  path: components/comment-input.yaml
                                  vars:
                                    comment_path: comment
                                    visibility_path: comment_internal
                                    placeholder: Add a comment about the recovery (optional).
                            - _var:
                                key: page_config.formFooter
                                default: []
                        else:
                          - id: error_card
                            type: Card
                            layout:
                              gap: 16
                            blocks:
                              _build.array.concat:
                                # Description lead-in — first child of the error
                                # card (plain Markdown; self-hides when unset).
                                - - _ref:
                                      path: components/action-description.yaml
                                      vars:
                                        content:
                                          _state: action.description
                                - - id: failure_banner
                                    type: Alert
                                    properties:
                                      type: error
                                      showIcon: true
                                      message:
                                        _state: action.status.0.error_message
                                      description:
                                        _nunjucks:
                                          template: |
                                            <pre>{{ metadata }}</pre>
                                          on:
                                            metadata:
                                              _js:
                                                args:
                                                  metadata:
                                                    _state: action.status.0.error_metadata
                                                fn: |
                                                  const { metadata } = args;
                                                  return JSON.stringify(metadata, null, 2);
                                - _var:
                                    key: page_config.formHeader
                                    default: []
                                - _ref:
                                    resolver: resolvers/makeActionsForm.js
                                    vars:
                                      form:
                                        _var:
                                          key: action_config.form_error
                                          default: []
                                      mode: error
                                - - _ref:
                                      path: components/comment-input.yaml
                                      vars:
                                        comment_path: comment
                                        visibility_path: comment_internal
                                        placeholder: Add a comment about the recovery (optional).
                                - _var:
                                    key: page_config.formFooter
                                    default: []
                # Floating action bar (shell `actions` slot): workflow extras on the
                # left, the single resolve_error verb on the right (grow spacer between).
                actions:
                  _build.array.concat:
                    - _var:
                        key: page_config.buttons.extra
                        default: []
                    - - id: action_bar_spacer
                        type: Box
                        layout:
                          flex: 1 1 0
                    - - id: button_resolve_error
                        type: Button
                        layout:
                          flex: 0 1 auto
                        visible:
                          _and:
                            - _var:
                                key: page_config.buttons.resolve_error.visible
                                default: true
                            - _state: action.buttons.resolve_error
                        properties:
                          title:
                            _var:
                              key: page_config.buttons.resolve_error.title
                              default: Resolve
                          type: primary
                          disabled:
                            _var:
                              key: page_config.buttons.resolve_error.disabled
                              default: false
                        events:
                          onClick:
                            _build.if:
                              test:
                                _build.ne:
                                  - _var:
                                      key: page_config.buttons.resolve_error.modal
                                      default: null
                                  - null
                              then:
                                - id: open_resolve_error_modal
                                  type: CallMethod
                                  params:
                                    method: open
                                    blockId: resolve_error_modal
                              else:
                                _build.array.concat:
                                  - - id: validate
                                      type: Validate
                                      params:
                                        regex:
                                          - ^form\.
                                  - _var:
                                      key: page_config.events.onSubmit
                                      default: []
                                  - - id: submit_resolve_error
                                      type: CallAPI
                                      params:
                                        endpointId:
                                          _module.endpointId: {{ workflow_type }}-submit
                                        payload:
                                          action_id:
                                            _state: action._id
                                          signal: resolve_error
                                          current_key:
                                            _state: action.key
                                          form:
                                            _state: form
                                          comment:
                                            _state: comment
                                          comment_visibility:
                                            _if:
                                              - _state: comment_internal
                                              - internal
                                              - shared
                                  # Terminal signal — return to the entity on success.
                                  - _ref:
                                      path: components/return-to-entity.yaml
                                      vars:
                                        entity_page_id:
                                          _state: action.entity_link.pageId
                                        entity_url_query:
                                          _state: action.entity_link.urlQuery
                                        success_message:
                                          _var:
                                            key: page_config.buttons.resolve_error.successMessage
                                            default: Resolved.
        # Universal-fields edit modal — opened by the title-bar ✎ chip.
        - _build.if:
            test:
              _build.gt:
                - _build.array.length:
                    _var:
                      key: action_config.universal_fields
                      default: []
                - 0
            then:
              - _ref:
                  path: components/universal-fields/universal-fields-modal.yaml
                  vars:
                    modal_id: universal_fields_edit_modal
                    state_path: fields
                    workflow_type: {{ workflow_type }}
                    action_id:
                      _state: action._id
                    allowed_edit:
                      _state: action.allowed.edit
                    show:
                      _var: action_config.universal_fields
                    on_complete:
                      - id: refetch_action_fields
                        type: Request
                        params: get_workflow_action
                      - id: reset_action_fields
                        type: SetState
                        params:
                          action:
                            _request: get_workflow_action
                      - id: update_fields_success
                        type: DisplayMessage
                        params:
                          status: success
                          content: Updated successfully.
            else: []
        # Optional ConfirmModal — renders iff page_config.buttons.resolve_error.modal is set.
        - _build.if:
            test:
              _build.ne:
                - _var:
                    key: page_config.buttons.resolve_error.modal
                    default: null
                - null
            then:
              - id: resolve_error_modal
                type: ConfirmModal
                properties:
                  width: 600
                  title:
                    _var:
                      key: page_config.buttons.resolve_error.modal.title
                      default: null
                  okText:
                    _var:
                      key: page_config.buttons.resolve_error.title
                      default: Resolve
                  content:
                    _var:
                      key: page_config.buttons.resolve_error.modal.content
                      default: You are resolving this error. Would you like to proceed?
                events:
                  onOk:
                    _build.array.concat:
                      - - id: validate
                          type: Validate
                          params:
                            regex:
                              - ^form\.
                      - _var:
                          key: page_config.events.onSubmit
                          default: []
                      - - id: submit_resolve_error
                          type: CallAPI
                          params:
                            endpointId:
                              _module.endpointId: {{ workflow_type }}-submit
                            payload:
                              action_id:
                                _state: action._id
                              signal: resolve_error
                              current_key:
                                _state: action.key
                              form:
                                _state: form
                              comment:
                                _state: comment
                              comment_visibility:
                                _if:
                                  - _state: comment_internal
                                  - internal
                                  - shared
                      # Terminal signal — return to the entity on success.
                      - _ref:
                          path: components/return-to-entity.yaml
                          vars:
                            entity_page_id:
                              _state: action.entity_link.pageId
                            entity_url_query:
                              _state: action.entity_link.urlQuery
                            success_message:
                              _var:
                                key: page_config.buttons.resolve_error.successMessage
                                default: Resolved.
            else: []
