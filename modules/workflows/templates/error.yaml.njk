# Error recovery page for a form action.
#
# Build-time vars (from makeActionPages.js): action_config, page_config,
# page_ids, workflow_type, connection_id. See view.yaml.njk.
#
# Stale-URL allowlist: [error]. Only renders during recovery; any other
# stage redirects to -view.
#
# Outer-card suppression checks action_config.form_error[0].form (not
# `form` — error has its own form schema).
#
# The `resolve_error` button is the only interaction button whose `title`
# is overridable per app (default "Resolve").
_ref:
  module: layout
  component: page
  vars:
    id:
      _var: page_ids.error
    title:
      _var:
        key: page_config.title
        default: null
    status:
      _state: action.status.0.stage
    status_enum:
      _ref: ../shared/enums/action_statuses.yaml
    show_back_button: true
    content_width:
      _var:
        key: page_config.maxWidth
        default: 750
    requests:
      _build.array.concat:
        - - _ref: requests/get_workflow_action.yaml
          - _ref:
              path: requests/get_entity.yaml.njk
              vars:
                connection_id: {{ connection_id }}
        - _var:
            key: page_config.requests
            default: []
    events:
      onMount:
        _build.array.concat:
          - - id: redirect_no_action
              type: Link
              skip:
                _ne:
                  - _url_query: action_id
                  - null
              params:
                back: true
            - id: get_action
              type: Request
              params: get_workflow_action
            - id: set_action
              type: SetState
              params:
                action:
                  _request: get_workflow_action
            - id: redirect_stale_status
              type: Link
              skip:
                _eq:
                  - _state: action.status.0.stage
                  - error
              params:
                pageId:
                  _module.pageId:
                    _var: page_ids.view
                urlQuery:
                  _url_query: true
            - id: get_entity
              type: Request
              params: get_entity
            - id: prime_form_state
              type: SetState
              params:
                form:
                  _state: action.form_values
                fields:
                  assignees:
                    _state: action.assignees
                  due_date:
                    _state: action.due_date
                  description:
                    _state: action.description
                comment: null
          - _var:
              key: page_config.events.onMount
              default: []
    blocks:
      _build.array.concat:
        # Card-interior content — outer-card suppression on form_error[0].form.
        # Two-column content row: error/recovery body (left) + read-only
        # universal-fields sidebar (right), gated on universal_fields non-empty.
        - - id: action_content_row
            type: Box
            layout:
              gap: 16
            blocks:
              _build.array.concat:
                - - id: form_column
                    type: Box
                    layout:
                      span:
                        _build.if:
                          test:
                            _build.gt:
                              - _build.array.length:
                                  _var:
                                    key: action_config.universal_fields
                                    default: []
                              - 0
                          then: 16
                          else: 24
                      sm:
                        span: 24
                    blocks:
                      _build.if:
                        test:
                          _build.ne:
                            - _var:
                                key: action_config.form_error.0.form
                                default: null
                            - null
                        then:
                          _build.array.concat:
                            - - id: failure_banner
                                type: Alert
                                properties:
                                  type: error
                                  showIcon: true
                                  message:
                                    _state: action.status.0.error_message
                                  description:
                                    _nunjucks:
                                      template: |
                                        <pre>{{ metadata }}</pre>
                                      on:
                                        metadata:
                                          _js:
                                            args:
                                              metadata:
                                                _state: action.status.0.error_metadata
                                            fn: |
                                              const { metadata } = args;
                                              return JSON.stringify(metadata, null, 2);
                            - _var:
                                key: page_config.formHeader
                                default: []
                            - _ref:
                                resolver: resolvers/makeActionsForm.js
                                vars:
                                  form:
                                    _var:
                                      key: action_config.form_error
                                      default: []
                                  mode: error
                            - - id: comment
                                type: TiptapInput
                                properties:
                                  title: Comment
                                  placeholder: Add a comment about the recovery (optional).
                            - _var:
                                key: page_config.formFooter
                                default: []
                        else:
                          - id: error_card
                            type: Card
                            layout:
                              gap: 16
                            blocks:
                              _build.array.concat:
                                - - id: failure_banner
                                    type: Alert
                                    properties:
                                      type: error
                                      showIcon: true
                                      message:
                                        _state: action.status.0.error_message
                                      description:
                                        _nunjucks:
                                          template: |
                                            <pre>{{ metadata }}</pre>
                                          on:
                                            metadata:
                                              _js:
                                                args:
                                                  metadata:
                                                    _state: action.status.0.error_metadata
                                                fn: |
                                                  const { metadata } = args;
                                                  return JSON.stringify(metadata, null, 2);
                                - _var:
                                    key: page_config.formHeader
                                    default: []
                                - _ref:
                                    resolver: resolvers/makeActionsForm.js
                                    vars:
                                      form:
                                        _var:
                                          key: action_config.form_error
                                          default: []
                                      mode: error
                                - - id: comment
                                    type: TiptapInput
                                    properties:
                                      title: Comment
                                      placeholder: Add a comment about the recovery (optional).
                                - _var:
                                    key: page_config.formFooter
                                    default: []
                - _build.if:
                    test:
                      _build.gt:
                        - _build.array.length:
                            _var:
                              key: action_config.universal_fields
                              default: []
                        - 0
                    then:
                      - id: sidebar_column
                        type: Box
                        layout:
                          span: 8
                          sm:
                            span: 24
                        blocks:
                          - _ref:
                              path: components/universal-fields/universal-fields.yaml
                              vars:
                                mode: display
                                kind: form
                                state_path: fields
                                workflow_type: {{ workflow_type }}
                                show:
                                  _var: action_config.universal_fields
                                action_data:
                                  assignees:
                                    _state: action.assignees
                                  assignee_docs:
                                    _state: action.assignee_docs
                                  due_date:
                                    _state: action.due_date
                                  description:
                                    _state: action.description
                    else: []
        # Floating-actions sticky button bar — single resolve_error button.
        - - _ref:
              module: layout
              component: floating-actions
              vars:
                actions:
                  - id: button_resolve_error
                    type: Button
                    layout:
                      flex: 0 1 auto
                    visible:
                      _and:
                        - _var:
                            key: page_config.buttons.resolve_error.visible
                            default: true
                        - _state: action.buttons.resolve_error
                    properties:
                      title:
                        _var:
                          key: page_config.buttons.resolve_error.title
                          default: Resolve
                      type: primary
                      disabled:
                        _var:
                          key: page_config.buttons.resolve_error.disabled
                          default: false
                    events:
                      onClick:
                        _build.if:
                          test:
                            _build.ne:
                              - _var:
                                  key: page_config.buttons.resolve_error.modal
                                  default: null
                              - null
                          then:
                            - id: open_resolve_error_modal
                              type: CallMethod
                              params:
                                method: open
                                blockId: resolve_error_modal
                          else:
                            _build.array.concat:
                              - - id: validate
                                  type: Validate
                                  params:
                                    regex:
                                      - ^form\.
                              - _var:
                                  key: page_config.events.onSubmit
                                  default: []
                              - - id: submit_resolve_error
                                  type: CallAPI
                                  params:
                                    endpointId:
                                      _module.endpointId: {{ workflow_type }}-submit
                                    payload:
                                      action_id:
                                        _state: action._id
                                      signal: resolve_error
                                      current_key:
                                        _state: action.key
                                      form:
                                        _state: form
                                      comment:
                                        _state: comment
        # Optional ConfirmModal — renders iff page_config.buttons.resolve_error.modal is set.
        - _build.if:
            test:
              _build.ne:
                - _var:
                    key: page_config.buttons.resolve_error.modal
                    default: null
                - null
            then:
              - id: resolve_error_modal
                type: ConfirmModal
                properties:
                  width: 600
                  title:
                    _var:
                      key: page_config.buttons.resolve_error.modal.title
                      default: null
                  okText:
                    _var:
                      key: page_config.buttons.resolve_error.title
                      default: Resolve
                  content:
                    _var:
                      key: page_config.buttons.resolve_error.modal.content
                      default: You are resolving this error. Would you like to proceed?
                events:
                  onOk:
                    _build.array.concat:
                      - - id: validate
                          type: Validate
                          params:
                            regex:
                              - ^form\.
                      - _var:
                          key: page_config.events.onSubmit
                          default: []
                      - - id: submit_resolve_error
                          type: CallAPI
                          params:
                            endpointId:
                              _module.endpointId: {{ workflow_type }}-submit
                            payload:
                              action_id:
                                _state: action._id
                              signal: resolve_error
                              current_key:
                                _state: action.key
                              form:
                                _state: form
                              comment:
                                _state: comment
            else: []
        # Activity timeline (Part 33) — events for this action, comments inline.
        - - id: activity_card
            type: Card
            properties:
              title: Activity
            blocks:
              - _ref:
                  module: events
                  component: events-timeline
                  vars:
                    reference_field: action_ids
                    reference_value:
                      _state: action._id
