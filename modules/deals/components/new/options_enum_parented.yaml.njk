# Module-local copy of apps/shared/enums/options_enum_parented.yaml.njk — see
# options_enum.yaml for why this is duplicated instead of _ref'd across the
# module boundary. Builds Selector options from an enum where each entry may
# carry a parent slug under `parent_key`, keeping only entries whose parent
# matches `parent` or that have no parent (universal entries, e.g. `other`).
# `parent` may be a runtime operator (e.g. `_state: form.sector`) — it is
# embedded into the pipeline and evaluated when `_mql.aggregate` runs, so
# options react to the selected parent.
# Vars: enum, parent, parent_key, colored_labels (default true).
_mql.aggregate:
  - - _var: enum
  - - $project:
        items:
          $objectToArray: $$ROOT
    - $unwind:
        path: $items
    - $match:
        $or:
          - items.v.{{ parent_key }}:
              _var: parent
          - items.v.{{ parent_key }}:
              $exists: false
    - $project:
        label:
          _if:
            test:
              _var:
                key: colored_labels
                default: true
            then:
              $cond:
                if:
                  $ifNull:
                    - $items.v.color
                    - false
                then:
                  $concat:
                    - '<span style="color: '
                    - $items.v.color
                    - '">'
                    - $items.v.title
                    - </span>
                else: $items.v.title
            else: $items.v.title
        value: $items.k
        style:
          _object.assign:
            - fontWeight: bold
            - _if:
                test:
                  _var:
                    key: colored_labels
                    default: true
                then:
                  color: $items.v.color
                else: {}
        tag:
          color: $items.v.color
          icon: $items.v.icon
          title: $items.v.title
