{# Default modal form for the ContactSelector wrapper (Task 8).

   Vars:
     key           (string, required) — state prefix for input ids
                   (wrapper passes "{id}_contact"); Nunjucks-interpolated
                   into each block id.
     new_contact   (operator/boolean) — truthy when the modal is in Add mode;
                   falsy when editing an existing contact. Email is locked
                   on edit (dedup key); name fields stay editable.
     required      (object) — { given_name, family_name, email } flags
                   forwarded from the wrapper's form_required var.
                   given_name/family_name default true, email defaults false.
     extra_blocks  (array) — extra input blocks appended after the core
                   three. Mirrors the form_profile / fields.profile pattern
                   other contacts module forms use. Apps that want phones
                   or custom fields pass them here.

   No onAddContact / onEditContact actions live here — those are on the
   wrapper. This form only provides inputs and validation.
#}
id: form_contact
type: Box
layout:
  gap: 8
style:
  margin: auto
blocks:
  _build.array.concat:
    - - id: {{ key }}.profile.given_name
        type: TextInput
        required:
          _var:
            key: required.given_name
            default: true
        layout:
          span: 12
        properties:
          title: First Name

      - id: {{ key }}.profile.family_name
        type: TextInput
        required:
          _var:
            key: required.family_name
            default: true
        layout:
          span: 12
        properties:
          title: Last Name

      - id: {{ key }}.email
        type: TextInput
        required:
          _var:
            key: required.email
            default: false
        layout:
          span: 24
        properties:
          title: Email
          placeholder: name@company.com
          disabled:
            _not:
              _var: new_contact
        validate:
          _ref:
            path: validate/email.yaml
            vars:
              field_name: {{ key }}.email
    - _var:
        key: extra_blocks
        default: []
