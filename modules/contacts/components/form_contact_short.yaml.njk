# Simple three-field contact form used inside the contact-selector modal.
#
# Inputs bind to `{id}_contact.profile.*` and `{id}_contact.email`. When the
# modal is closed the plugin resets `{id}_contact` to null, so all `required`
# flags are gated on `{id}_contact` being non-null — otherwise a page-level
# Validate action would treat the closed modal's hidden inputs as missing.
#
# Required vars:
#   id: (string) Picker instance id.
#
# Optional vars:
#   required: (object, default: { given_name: true, family_name: true, email: true })

id: {{ id | replace(".", "_") }}_form
type: Box
layout:
  gap: 8
blocks:
  - id: {{ id | replace(".", "_") }}_contact.profile.given_name
    type: TextInput
    required:
      _and:
        - _ne:
            - _state: {{ id | replace(".", "_") }}_contact
              ~ignoreBuildChecks: true
            - null
        - _var:
            key: required.given_name
            default: true
    properties:
      title: First Name
      size: small
  - id: {{ id | replace(".", "_") }}_contact.profile.family_name
    type: TextInput
    required:
      _and:
        - _ne:
            - _state: {{ id | replace(".", "_") }}_contact
              ~ignoreBuildChecks: true
            - null
        - _var:
            key: required.family_name
            default: true
    properties:
      title: Last Name
      size: small
  - id: {{ id | replace(".", "_") }}_contact.email
    type: TextInput
    required:
      _and:
        - _ne:
            - _state: {{ id | replace(".", "_") }}_contact
              ~ignoreBuildChecks: true
            - null
        - _var:
            key: required.email
            default: true
    properties:
      title: Email
      placeholder: "name@company.com"
      size: small
      disabled:
        _and:
          - _eq:
              - _state: {{ id | replace(".", "_") }}_edit
                ~ignoreBuildChecks: true
              - true
          - _ne:
              - _state: {{ id | replace(".", "_") }}_contact.email
                ~ignoreBuildChecks: true
              - null
    validate:
      - message: Enter a valid email address.
        pass:
          _or:
            - _eq:
                - _if_none:
                    - _state: {{ id | replace(".", "_") }}_contact.email
                      ~ignoreBuildChecks: true
                    - ""
                - ""
            - _regex:
                on:
                  _state: {{ id | replace(".", "_") }}_contact.email
                  ~ignoreBuildChecks: true
                pattern: "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
